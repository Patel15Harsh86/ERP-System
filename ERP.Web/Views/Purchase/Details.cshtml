@using ERP.Core.Models
@model PurchaseOrder

@{
    ViewData["Title"] = "PO Details";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Purchase Order - @Model.PONumber</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; }
        .po { max-width: 800px; margin: 30px auto; background: white;
              border-radius: 12px; overflow: hidden;
              box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
        .header { background: linear-gradient(135deg, #1a237e, #1565c0);
                  color: white; padding: 30px; }
        .body { padding: 30px; }
        @@media print {
            body { background: white; }
            .po { box-shadow: none; margin: 0; }
            .no-print { display: none; }
        }
    </style>
</head>
<body>
    <div class="po">
        <div class="header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-1">SmartERP</h4>
                    <p class="mb-0 opacity-75">Purchase Order</p>
                </div>
                <div class="text-end">
                    <h5 class="mb-1">PURCHASE ORDER</h5>
                    <p class="mb-0 opacity-75">#@Model.PONumber</p>
                </div>
            </div>
        </div>

        <div class="body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="fw-bold mb-2">Vendor Details:</h6>
                    <p class="mb-1 fw-bold">@Model.Vendor?.VendorName</p>
                    <p class="mb-1 text-muted">@Model.Vendor?.ContactPerson</p>
                    <p class="mb-1 text-muted">@Model.Vendor?.Email</p>
                    <p class="mb-0 text-muted">@Model.Vendor?.Phone</p>
                </div>
                <div class="col-md-6 text-end">
                    <p class="mb-1">
                        <strong>PO Date:</strong>
                        @Model.PODate.ToString("dd MMM yyyy")
                    </p>
                    <p class="mb-1">
                        <strong>Expected Delivery:</strong>
                        @Model.ExpectedDelivery.ToString("dd MMM yyyy")
                    </p>
                    <p class="mb-1">
                        <strong>Status:</strong>
                        <span class="badge @(Model.Status == "Draft" ? "bg-warning text-dark" : Model.Status == "Approved" ? "bg-success" : "bg-info")">
                            @Model.Status
                        </span>
                    </p>
                </div>
            </div>

            <table class="table table-bordered mb-4">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Unit Price</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@i++</td>
                            <td>@item.Product?.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>₹@item.UnitPrice.ToString("N2")</td>
                            <td>₹@item.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-primary fw-bold">
                        <td colspan="4" class="text-end">Total Amount:</td>
                        <td>₹@Model.TotalAmount.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>

            @if (Model.Notes != null)
            {
                <div class="alert alert-light">
                    <strong>Notes:</strong> @Model.Notes
                </div>
            }

            <div class="row mt-5">
                <div class="col-md-6 text-center">
                    <div style="border-top: 1px solid #333; padding-top: 8px; margin-top: 40px;">
                        Prepared By
                    </div>
                </div>
                <div class="col-md-6 text-center">
                    <div style="border-top: 1px solid #333; padding-top: 8px; margin-top: 40px;">
                        Approved By
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4 no-print">
                <a href="/Purchase/Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
                <button onclick="window.print()" class="btn btn-primary">
                    <i class="fas fa-print me-2"></i>Print PO
                </button>
            </div>
        </div>
    </div>
</body>
</html>