@using ERP.Core.Models
@model IEnumerable<PurchaseOrder>

@{
    ViewData["Title"] = "Purchase Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Purchase Orders</h4>
        <p class="text-muted mb-0">Manage vendor purchase orders</p>
    </div>
    <a href="/Purchase/Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>New PO
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-primary mb-1"><i class="fas fa-file-alt fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count()</h4>
            <p class="text-muted mb-0">Total POs</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-warning mb-1"><i class="fas fa-clock fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(o => o.Status == "Draft")</h4>
            <p class="text-muted mb-0">Draft</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-success mb-1"><i class="fas fa-check fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(o => o.Status == "Approved")</h4>
            <p class="text-muted mb-0">Approved</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-info mb-1"><i class="fas fa-truck fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(o => o.Status == "Received")</h4>
            <p class="text-muted mb-0">Received</p>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>PO Number</th>
                        <th>Vendor</th>
                        <th>Date</th>
                        <th>Expected Delivery</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                <i class="fas fa-file-alt fa-2x mb-2 d-block"></i>
                                No purchase orders yet!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark">@o.PONumber</span></td>
                                <td>@o.Vendor?.VendorName</td>
                                <td>@o.PODate.ToString("dd MMM yyyy")</td>
                                <td>@o.ExpectedDelivery.ToString("dd MMM yyyy")</td>
                                <td>@o.Items.Count items</td>
                                <td>₹@o.TotalAmount.ToString("N2")</td>
                                <td>
                                    <span class="badge @(o.Status == "Draft" ? "bg-warning text-dark" : o.Status == "Approved" ? "bg-success" : o.Status == "Received" ? "bg-info" : "bg-secondary")">
                                        @o.Status
                                    </span>
                                </td>
                                <td>
                                    <a href="/Purchase/Details/@o.Id"
                                       class="btn btn-sm btn-outline-info me-1">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (o.Status == "Draft")
                                    {
                                        <form method="post" action="/Purchase/Approve"
                                              style="display:inline">
                                            <input type="hidden" name="id" value="@o.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-success me-1">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (o.Status == "Approved")
                                    {
                                        <form method="post" action="/Purchase/Receive"
                                              style="display:inline">
                                            <input type="hidden" name="id" value="@o.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-truck"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>