@using ERP.Core.Models
@model IEnumerable<AuditLog>

@{
    ViewData["Title"] = "Audit Log";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Audit Log</h4>
        <p class="text-muted mb-0">Track all user actions in the system</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-primary mb-1"><i class="fas fa-list fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count()</h4>
            <p class="text-muted mb-0">Total Logs</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-success mb-1"><i class="fas fa-plus-circle fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(a => a.Action == "Create")</h4>
            <p class="text-muted mb-0">Creates</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-warning mb-1"><i class="fas fa-edit fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(a => a.Action == "Update")</h4>
            <p class="text-muted mb-0">Updates</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-danger mb-1"><i class="fas fa-trash fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(a => a.Action == "Delete")</h4>
            <p class="text-muted mb-0">Deletes</p>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date & Time</th>
                        <th>User</th>
                        <th>Module</th>
                        <th>Action</th>
                        <th>Description</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="fas fa-list fa-2x mb-2 d-block"></i>
                                No audit logs yet!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>@log.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>@log.UserEmail</td>
                                <td>
                                    <span class="badge bg-info">@log.Module</span>
                                </td>
                                <td>
                                    <span class="badge @(log.Action == "Create" ? "bg-success" : log.Action == "Delete" ? "bg-danger" : log.Action == "Update" ? "bg-warning text-dark" : "bg-secondary")">
                                        @log.Action
                                    </span>
                                </td>
                                <td>@log.Description</td>
                                <td>@log.IpAddress</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>