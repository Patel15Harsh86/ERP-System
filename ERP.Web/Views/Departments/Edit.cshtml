@using ERP.Core.Models
@model Department

@{
    ViewData["Title"] = "Edit Department";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Edit Department</h4>
    </div>
    <a asp-controller="Departments" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="card border-0 shadow-sm" style="max-width:500px">
    <div class="card-body p-4">
        <form method="post" action="/Departments/Edit/@Model.Id">
            <div class="mb-3">
                <label class="form-label fw-500">Department Name</label>
                <input type="text" name="DepartmentName" class="form-control"
                       value="@Model.DepartmentName" required />
            </div>
            <div class="mb-4">
                <label class="form-label fw-500">Description</label>
                <textarea name="Description" class="form-control"
                          rows="3">@Model.Description</textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-save me-2"></i>Update Department
            </button>
        </form>
    </div>
</div>