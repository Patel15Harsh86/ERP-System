@using ERP.Core.Models
@model IEnumerable<Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Departments</h4>
        <p class="text-muted mb-0">Manage company departments</p>
    </div>
    <a href="/Departments/Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add Department
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Department Name</th>
                    <th>Description</th>
                    <th>Employees</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            No departments found!
                        </td>
                    </tr>
                }
                else
                {
                    int i = 1;
                    @foreach (var d in Model)
                    {
                        <tr>
                            <td>@i++</td>
                            <td class="fw-500">@d.DepartmentName</td>
                            <td>@d.Description</td>
                            <td>
                                <span class="badge bg-info">
                                    @d.Employees.Count employees
                                </span>
                            </td>
                            <td>
                                <a href="/Departments/Edit/@d.Id"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form method="post" action="/Departments/Delete/@d.Id"
                                      style="display:inline"
                                      onsubmit="return confirm('Delete this department?')">
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>