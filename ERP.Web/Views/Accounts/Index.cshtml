@{
    ViewData["Title"] = "Accounts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Accounts</h4>
        <p class="text-muted mb-0">Finance & Accounts Management</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-success mb-1"><i class="fas fa-arrow-up fa-2x"></i></div>
            <h4 class="fw-bold text-success">₹1,29,800</h4>
            <p class="text-muted mb-0">Total Income</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-danger mb-1"><i class="fas fa-arrow-down fa-2x"></i></div>
            <h4 class="fw-bold text-danger">₹45,000</h4>
            <p class="text-muted mb-0">Total Expenses</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-primary mb-1"><i class="fas fa-balance-scale fa-2x"></i></div>
            <h4 class="fw-bold text-primary">₹84,800</h4>
            <p class="text-muted mb-0">Net Profit</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-warning mb-1"><i class="fas fa-file-invoice fa-2x"></i></div>
            <h4 class="fw-bold text-warning">₹1,29,800</h4>
            <p class="text-muted mb-0">Pending Payments</p>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold">
                <i class="fas fa-file-invoice me-2 text-primary"></i>Recent Invoices
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Invoice</th>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>INV-2026-001</td>
                            <td>ABC Company</td>
                            <td>₹1,29,800</td>
                            <td><span class="badge bg-danger">Unpaid</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold">
                <i class="fas fa-chart-pie me-2 text-success"></i>Quick Summary
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless">
                    <tr>
                        <td class="text-muted">Total Sales</td>
                        <td class="fw-bold text-end">₹1,29,800</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Total Purchases</td>
                        <td class="fw-bold text-end">₹45,000</td>
                    </tr>
                    <tr>
                        <td class="text-muted">Total Payroll</td>
                        <td class="fw-bold text-end">₹0</td>
                    </tr>
                    <tr class="border-top">
                        <td class="fw-bold">Net Balance</td>
                        <td class="fw-bold text-end text-success">₹84,800</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>