@using ERP.Core.Models
@model IEnumerable<Customer>

@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Customers</h4>
        <p class="text-muted mb-0">Manage your customers</p>
    </div>
    <a href="/Customers/Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add Customer
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-primary mb-1"><i class="fas fa-user-tie fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count()</h4>
            <p class="text-muted mb-0">Total Customers</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-success mb-1"><i class="fas fa-rupee-sign fa-2x"></i></div>
            <h4 class="fw-bold">₹@Model.Sum(c => c.CreditLimit).ToString("N0")</h4>
            <p class="text-muted mb-0">Total Credit Limit</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-warning mb-1"><i class="fas fa-map-marker-alt fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Select(c => c.Address).Distinct().Count()</h4>
            <p class="text-muted mb-0">Locations</p>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="p-3 border-bottom">
            <input type="text" id="searchInput" class="form-control"
                   placeholder="Search customers..." style="max-width:300px" />
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="custTable">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Customer Name</th>
                        <th>Contact Person</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>GST Number</th>
                        <th>Credit Limit</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                <i class="fas fa-user-tie fa-2x mb-2 d-block"></i>
                                No customers found!
                            </td>
                        </tr>
                    }
                    else
                    {
                        int i = 1;
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td>@i++</td>
                                <td class="fw-500">@c.CustomerName</td>
                                <td>@c.ContactPerson</td>
                                <td>@c.Email</td>
                                <td>@c.Phone</td>
                                <td>@c.GSTNumber</td>
                                <td>₹@c.CreditLimit.ToString("N0")</td>
                                <td>
                                    <a href="/Customers/Edit/@c.Id"
                                       class="btn btn-sm btn-outline-primary me-1">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/Customers/Details/@c.Id"
                                       class="btn btn-sm btn-outline-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            const search = this.value.toLowerCase();
            document.querySelectorAll('#custTable tbody tr').forEach(row => {
                row.style.display =
                    row.textContent.toLowerCase().includes(search) ? '' : 'none';
            });
        });
    </script>
}