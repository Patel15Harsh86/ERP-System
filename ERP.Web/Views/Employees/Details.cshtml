@using ERP.Core.DTOs
@model EmployeeDto

@{
    ViewData["Title"] = "Employee Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Employee Details</h4>
        <p class="text-muted mb-0">@Model.EmployeeCode</p>
    </div>
    <a asp-controller="Employees" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <div class="row g-4">
            <div class="col-md-3 text-center">
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                     style="width:100px;height:100px">
                    <i class="fas fa-user fa-3x text-white"></i>
                </div>
                <h5 class="fw-bold">@Model.FullName</h5>
                <span class="badge bg-success">@Model.Status</span>
            </div>
            <div class="col-md-9">
                <div class="row g-3">
                    <div class="col-md-6">
                        <p class="text-muted mb-1">Employee Code</p>
                        <h6 class="fw-bold">@Model.EmployeeCode</h6>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted mb-1">Full Name</p>
                        <h6 class="fw-bold">@Model.FullName</h6>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted mb-1">Email</p>
                        <h6 class="fw-bold">@Model.Email</h6>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted mb-1">Phone</p>
                        <h6 class="fw-bold">@Model.Phone</h6>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted mb-1">Department</p>
                        <h6 class="fw-bold">@Model.Department</h6>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted mb-1">Designation</p>
                        <h6 class="fw-bold">@Model.Designation</h6>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted mb-1">Date of Joining</p>
                        <h6 class="fw-bold">@Model.DateOfJoining.ToString("dd MMM yyyy")</h6>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted mb-1">Status</p>
                        <span class="badge bg-success">@Model.Status</span>
                    </div>
                </div>
                <div class="mt-4">
                    <a href="/Employees/Edit/@Model.Id" class="btn btn-primary me-2">
                        <i class="fas fa-edit me-2"></i>Edit Employee
                    </a>
                    <a href="/Employees" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>