@using ERP.Core.Models
@model Invoice

@{
    ViewData["Title"] = "Invoice Details";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Invoice @Model.InvoiceNumber</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
          rel="stylesheet" />
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; }
        .invoice { max-width: 800px; margin: 30px auto; background: white;
                   border-radius: 12px; overflow: hidden;
                   box-shadow: 0 4px 20px rgba(0,0,0,0.1); }
        .header { background: linear-gradient(135deg, #1a237e, #1565c0);
                  color: white; padding: 30px; }
        .body { padding: 30px; }
    </style>
</head>
<body>
    <div class="invoice">
        <div class="header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-1">ERP System</h4>
                    <p class="mb-0 opacity-75">Tax Invoice</p>
                </div>
                <div class="text-end">
                    <h5 class="mb-1">INVOICE</h5>
                    <p class="mb-0 opacity-75">#@Model.InvoiceNumber</p>
                </div>
            </div>
        </div>
        <div class="body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="fw-bold mb-2">Bill To:</h6>
                    <p class="mb-1 fw-bold">@Model.SalesOrder?.Customer?.CustomerName</p>
                    <p class="mb-1 text-muted">@Model.SalesOrder?.Customer?.Email</p>
                    <p class="mb-0 text-muted">@Model.SalesOrder?.Customer?.Phone</p>
                </div>
                <div class="col-md-6 text-end">
                    <p class="mb-1">
                        <strong>Invoice Date:</strong>
                        @Model.InvoiceDate.ToString("dd MMM yyyy")
                    </p>
                    <p class="mb-1">
                        <strong>Due Date:</strong>
                        @Model.DueDate.ToString("dd MMM yyyy")
                    </p>
                    <p class="mb-0">
                        <strong>Order No:</strong>
                        @Model.SalesOrder?.OrderNumber
                    </p>
                </div>
            </div>

            <table class="table table-bordered mb-4">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Unit Price</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var item in Model.SalesOrder?.Items
                                        ?? new List<SalesOrderItem>())
                    {
                        <tr>
                            <td>@i++</td>
                            <td>@item.Product?.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>₹@item.UnitPrice.ToString("N2")</td>
                            <td>₹@item.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="d-flex justify-content-end mb-4">
                <table class="table table-sm" style="max-width:300px">
                    <tr>
                        <td>Sub Total:</td>
                        <td class="text-end">
                            ₹@Model.SalesOrder?.SubTotal.ToString("N2")
                        </td>
                    </tr>
                    <tr>
                        <td>Tax (18%):</td>
                        <td class="text-end">
                            ₹@Model.SalesOrder?.TaxAmount.ToString("N2")
                        </td>
                    </tr>
                    <tr class="table-primary fw-bold">
                        <td>Total:</td>
                        <td class="text-end">₹@Model.Amount.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td>Paid:</td>
                        <td class="text-end text-success">
                            ₹@Model.PaidAmount.ToString("N2")
                        </td>
                    </tr>
                    <tr class="table-danger fw-bold">
                        <td>Balance:</td>
                        <td class="text-end">
                            ₹@((Model.Amount - Model.PaidAmount).ToString("N2"))
                        </td>
                    </tr>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <span class="badge @(Model.Status == "Paid" ?
                                          "bg-success" : "bg-danger") fs-6">
                    @Model.Status
                </span>
                <div>
                    <button onclick="window.print()" class="btn btn-primary me-2">
                        <i class="fas fa-print me-2"></i>Print Invoice
                    </button>
                    <a href="/Sales/Invoices" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Back to Invoices
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>