@using ERP.Core.Models
@model IEnumerable<Invoice>

@{
    ViewData["Title"] = "Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Invoices</h4>
        <p class="text-muted mb-0">Manage all invoices</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-primary mb-1"><i class="fas fa-file-invoice fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count()</h4>
            <p class="text-muted mb-0">Total Invoices</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-danger mb-1"><i class="fas fa-clock fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(i => i.Status == "Unpaid")</h4>
            <p class="text-muted mb-0">Unpaid</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-success mb-1"><i class="fas fa-check-circle fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(i => i.Status == "Paid")</h4>
            <p class="text-muted mb-0">Paid</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-warning mb-1"><i class="fas fa-rupee-sign fa-2x"></i></div>
            <h4 class="fw-bold">₹@Model.Sum(i => i.Amount).ToString("N0")</h4>
            <p class="text-muted mb-0">Total Amount</p>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Invoice No</th>
                        <th>Customer</th>
                        <th>Order No</th>
                        <th>Invoice Date</th>
                        <th>Due Date</th>
                        <th>Amount</th>
                        <th>Paid</th>
                        <th>Balance</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center py-4 text-muted">
                                <i class="fas fa-file-invoice fa-2x mb-2 d-block"></i>
                                No invoices yet!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var inv in Model)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark">@inv.InvoiceNumber</span></td>
                                <td>@inv.SalesOrder?.Customer?.CustomerName</td>
                                <td>@inv.SalesOrder?.OrderNumber</td>
                                <td>@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                                <td>@inv.DueDate.ToString("dd MMM yyyy")</td>
                                <td>₹@inv.Amount.ToString("N2")</td>
                                <td>₹@inv.PaidAmount.ToString("N2")</td>
                                <td class="fw-bold">₹@((inv.Amount - inv.PaidAmount).ToString("N2"))</td>
                                <td>
                                    <span class="badge @(inv.Status == "Paid" ? "bg-success" : inv.Status == "PartiallyPaid" ? "bg-warning text-dark" : "bg-danger")">
                                        @inv.Status
                                    </span>
                                </td>
                                <td>
                                    <a href="/Sales/InvoiceDetails/@inv.Id"
                                       class="btn btn-sm btn-outline-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>