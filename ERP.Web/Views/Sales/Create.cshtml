@{
    ViewData["Title"] = "New Sales Order";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">New Sales Order</h4>
        <p class="text-muted mb-0">Create a new sales order</p>
    </div>
    <a asp-controller="Sales" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form method="post" action="/Sales/Create" id="orderForm">
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-500">Customer</label>
                    <select name="customerId" class="form-select" required>
                        <option value="">-- Select Customer --</option>
                        @foreach (var c in ViewBag.Customers)
                        {
                            <option value="@c.Id">@c.CustomerName</option>
                        }
                    </select>
                </div>
            </div>

            <h6 class="fw-bold mb-3">Order Items</h6>
            <div id="items">
                <div class="row g-2 mb-2 item-row">
                    <div class="col-md-4">
                        <select name="productIds" class="form-select product-select" required>
                            <option value="">-- Select Product --</option>
                            @foreach (var p in ViewBag.Products)
                            {
                                <option value="@p.Id" data-price="@p.SalePrice">
                                    @p.ProductName (Stock: @p.CurrentStock)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <input type="number" name="quantities" class="form-control quantity"
                               placeholder="Quantity" min="1" required />
                    </div>
                    <div class="col-md-3">
                        <input type="number" name="prices" class="form-control price"
                               placeholder="Unit Price" step="0.01" required />
                    </div>
                    <div class="col-md-2">
                        <input type="text" class="form-control amount"
                               placeholder="Amount" readonly />
                    </div>
                </div>
            </div>

            <button type="button" class="btn btn-outline-primary btn-sm mt-2"
                    onclick="addItem()">
                <i class="fas fa-plus me-1"></i>Add Item
            </button>

            <div class="card bg-light mt-4 p-3">
                <div class="row">
                    <div class="col-md-8"></div>
                    <div class="col-md-4">
                        <table class="table table-sm mb-0">
                            <tr>
                                <td>Sub Total:</td>
                                <td class="text-end fw-bold" id="subTotal">₹0.00</td>
                            </tr>
                            <tr>
                                <td>Tax (18%):</td>
                                <td class="text-end" id="taxAmount">₹0.00</td>
                            </tr>
                            <tr class="table-primary">
                                <td class="fw-bold">Total:</td>
                                <td class="text-end fw-bold" id="totalAmount">₹0.00</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fas fa-save me-2"></i>Save Order
                </button>
                <a asp-controller="Sales" asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function addItem() {
            const template = document.querySelector('.item-row').cloneNode(true);
            template.querySelectorAll('input').forEach(i => i.value = '');
            document.getElementById('items').appendChild(template);
            bindEvents();
        }

        function bindEvents() {
            document.querySelectorAll('.product-select').forEach(sel => {
                sel.onchange = function() {
                    const price = this.options[this.selectedIndex].dataset.price;
                    const row = this.closest('.item-row');
                    row.querySelector('.price').value = price;
                    calculateRow(row);
                };
            });
            document.querySelectorAll('.quantity, .price').forEach(inp => {
                inp.oninput = function() {
                    calculateRow(this.closest('.item-row'));
                };
            });
        }

        function calculateRow(row) {
            const qty = parseFloat(row.querySelector('.quantity').value) || 0;
            const price = parseFloat(row.querySelector('.price').value) || 0;
            row.querySelector('.amount').value = '₹' + (qty * price).toFixed(2);
            calculateTotal();
        }

        function calculateTotal() {
            let sub = 0;
            document.querySelectorAll('.item-row').forEach(row => {
                const qty = parseFloat(row.querySelector('.quantity').value) || 0;
                const price = parseFloat(row.querySelector('.price').value) || 0;
                sub += qty * price;
            });
            const tax = sub * 0.18;
            document.getElementById('subTotal').textContent = '₹' + sub.toFixed(2);
            document.getElementById('taxAmount').textContent = '₹' + tax.toFixed(2);
            document.getElementById('totalAmount').textContent = '₹' + (sub + tax).toFixed(2);
        }

        bindEvents();
    </script>
}