@using ERP.Core.Models
@model IEnumerable<SalesOrder>

@{
    ViewData["Title"] = "Sales Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Sales Orders</h4>
        <p class="text-muted mb-0">Manage all sales orders</p>
    </div>
    <a href="/Sales/Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>New Order
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-primary mb-1"><i class="fas fa-shopping-cart fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count()</h4>
            <p class="text-muted mb-0">Total Orders</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-warning mb-1"><i class="fas fa-clock fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(o => o.Status == "Pending")</h4>
            <p class="text-muted mb-0">Pending</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-success mb-1"><i class="fas fa-check fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(o => o.Status == "Invoiced")</h4>
            <p class="text-muted mb-0">Invoiced</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-danger mb-1"><i class="fas fa-rupee-sign fa-2x"></i></div>
            <h4 class="fw-bold">₹@Model.Sum(o => o.TotalAmount).ToString("N0")</h4>
            <p class="text-muted mb-0">Total Value</p>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="p-3 border-bottom">
            <input type="text" id="searchInput" class="form-control"
                   placeholder="Search orders..." style="max-width:300px" />
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="ordersTable">
                <thead class="table-light">
                    <tr>
                        <th>Order No</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Items</th>
                        <th>Sub Total</th>
                        <th>Tax (18%)</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-4 text-muted">
                                <i class="fas fa-shopping-cart fa-2x mb-2 d-block"></i>
                                No sales orders yet. Create your first order!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark">@o.OrderNumber</span></td>
                                <td>@o.Customer?.CustomerName</td>
                                <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                                <td>@o.Items.Count items</td>
                                <td>₹@o.SubTotal.ToString("N2")</td>
                                <td>₹@o.TaxAmount.ToString("N2")</td>
                                <td class="fw-bold">₹@o.TotalAmount.ToString("N2")</td>
                                <td>
                                    <span class="badge @(o.Status == "Pending" ? "bg-warning text-dark" : o.Status == "Invoiced" ? "bg-success" : "bg-info")">
                                        @o.Status
                                    </span>
                                </td>
                                <td>
                                    <a href="/Sales/Details/@o.Id"
                                       class="btn btn-sm btn-outline-info me-1">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (o.Status == "Pending")
                                    {
                                        <form method="post" action="/Sales/GenerateInvoice"
                                              style="display:inline">
                                            <input type="hidden" name="orderId" value="@o.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-success">
                                                <i class="fas fa-file-invoice"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            const search = this.value.toLowerCase();
            document.querySelectorAll('#ordersTable tbody tr').forEach(row => {
                row.style.display =
                    row.textContent.toLowerCase().includes(search) ? '' : 'none';
            });
        });
    </script>
}