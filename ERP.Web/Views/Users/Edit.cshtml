@using ERP.Core.Models
@model ApplicationUser

@{
    ViewData["Title"] = "Edit User";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Edit User</h4>
        <p class="text-muted mb-0">@Model.Email</p>
    </div>
    <a asp-controller="Users" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold">User Details</div>
            <div class="card-body p-4">
                <form method="post" action="/Users/Edit/@Model.Id">
                    <div class="mb-3">
                        <label class="form-label fw-500">Full Name</label>
                        <input type="text" name="fullName" class="form-control"
                               value="@Model.FullName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-500">Email</label>
                        <input type="email" class="form-control"
                               value="@Model.Email" disabled />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-500">Role</label>
                        <select name="role" class="form-select" required>
                            @foreach (var role in ViewBag.Roles)
                            {
                                if (ViewBag.CurrentRole == role.Name)
                                {
                                    <option value="@role.Name" selected>@role.Name</option>
                                }
                                else
                                {
                                    <option value="@role.Name">@role.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-500">Status</label>
                        <select name="isActive" class="form-select">
                            @if (Model.IsActive)
                            {
                                <option value="true" selected>Active</option>
                                <option value="false">Inactive</option>
                            }
                            else
                            {
                                <option value="true">Active</option>
                                <option value="false" selected>Inactive</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-save me-2"></i>Update User
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold">Reset Password</div>
            <div class="card-body p-4">
                <form method="post" action="/Users/ResetPassword">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label fw-500">New Password</label>
                        <input type="password" name="newPassword" class="form-control"
                               placeholder="Enter new password" required />
                    </div>
                    <button type="submit" class="btn btn-warning w-100">
                        <i class="fas fa-key me-2"></i>Reset Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>