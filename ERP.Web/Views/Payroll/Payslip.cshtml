@using ERP.Core.Models
@model PayrollRun

@{
    ViewData["Title"] = "Payslip";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Payslip - @Model.Employee?.FirstName @Model.Employee?.LastName</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f0f2f5;
        }

        .payslip {
            max-width: 750px;
            margin: 30px auto;
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .header {
            background: linear-gradient(135deg, #1a237e, #1565c0);
            color: white;
            padding: 30px;
        }

        .body {
            padding: 30px;
        }

        .earning {
            color: #2e7d32;
        }

        .deduction {
            color: #c62828;
        }

        .total-row {
            background: #e8f0fe;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="payslip">
        <div class="header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-1">ERP System</h4>
                    <p class="mb-0 opacity-75">Payslip for @Model.MonthName</p>
                </div>
                <div class="text-end">
                    <h5 class="mb-1">PAYSLIP</h5>
                    <p class="mb-0 opacity-75">@Model.MonthName</p>
                </div>
            </div>
        </div>

        <div class="body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="fw-bold mb-3">Employee Details</h6>
                    <table class="table table-sm table-borderless">
                        <tr><td class="text-muted">Name:</td><td class="fw-500">@Model.Employee?.FirstName @Model.Employee?.LastName</td></tr>
                        <tr><td class="text-muted">Code:</td><td>@Model.Employee?.EmployeeCode</td></tr>
                        <tr><td class="text-muted">Department:</td><td>@Model.Employee?.Department?.DepartmentName</td></tr>
                        <tr><td class="text-muted">Month:</td><td>@Model.MonthName</td></tr>
                    </table>
                </div>
            </div>

            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Earnings</th>
                        <th class="text-end">Amount (₹)</th>
                        <th>Deductions</th>
                        <th class="text-end">Amount (₹)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="earning">Basic Salary</td>
                        <td class="text-end earning">@Model.BasicSalary.ToString("N2")</td>
                        <td class="deduction">PF Deduction</td>
                        <td class="text-end deduction">@Model.PFDeduction.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="earning">HRA</td>
                        <td class="text-end earning">@Model.HRA.ToString("N2")</td>
                        <td class="deduction">Tax Deduction</td>
                        <td class="text-end deduction">@Model.TaxDeduction.ToString("N2")</td>
                    </tr>
                    <tr>
                        <td class="earning">Allowances</td>
                        <td class="text-end earning">@Model.Allowances.ToString("N2")</td>
                        <td class="deduction">Other Deductions</td>
                        <td class="text-end deduction">@Model.OtherDeductions.ToString("N2")</td>
                    </tr>
                    <tr class="total-row">
                        <td>Gross Salary</td>
                        <td class="text-end">₹@Model.GrossSalary.ToString("N2")</td>
                        <td>Total Deductions</td>
                        <td class="text-end text-danger">₹@((Model.PFDeduction + Model.TaxDeduction + Model.OtherDeductions).ToString("N2"))</td>
                    </tr>
                </tbody>
            </table>

            <div class="d-flex justify-content-end mt-3">
                <div class="card bg-primary text-white p-3" style="min-width:200px">
                    <p class="mb-1 opacity-75">Net Salary</p>
                    <h4 class="mb-0">₹@Model.NetSalary.ToString("N2")</h4>
                </div>
            </div>

            <div class="mt-4 d-print-none">
                <button onclick="window.print()" class="btn btn-primary">
                    <i class="fas fa-print me-2"></i>Print Payslip
                </button>
                <a href="/Payroll" class="btn btn-outline-secondary ms-2">Back</a>
            </div>
        </div>
    </div>
</body>
</html>