@using ERP.Core.Models
@model IEnumerable<StockMovement>

@{
    ViewData["Title"] = "Stock History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Stock Movement History</h4>
        <p class="text-muted mb-0">All stock in and out transactions</p>
    </div>
    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to Products
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" action="/Products/StockHistory">
            <div class="d-flex gap-3">
                <select name="id" class="form-select" style="max-width:300px">
                    <option value="">-- All Products --</option>
                    @foreach (var p in ViewBag.Products)
                    {
                        if (ViewBag.SelectedProduct == p.Id)
                        {
                            <option value="@p.Id" selected>@p.ProductName</option>
                        }
                        else
                        {
                            <option value="@p.Id">@p.ProductName</option>
                        }
                    }
                </select>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-filter me-2"></i>Filter
                </button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-success mb-1"><i class="fas fa-plus-circle fa-2x"></i></div>
            <h4 class="fw-bold text-success">@Model.Where(m => m.MovementType == "IN").Sum(m => m.Quantity)</h4>
            <p class="text-muted mb-0">Total Stock In</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-danger mb-1"><i class="fas fa-minus-circle fa-2x"></i></div>
            <h4 class="fw-bold text-danger">@Model.Where(m => m.MovementType == "OUT").Sum(m => m.Quantity)</h4>
            <p class="text-muted mb-0">Total Stock Out</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-primary mb-1"><i class="fas fa-exchange-alt fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count()</h4>
            <p class="text-muted mb-0">Total Transactions</p>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Product</th>
                        <th>Type</th>
                        <th>Quantity</th>
                        <th>Reference</th>
                        <th>Notes</th>
                        <th>By</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                No stock movements found!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var m in Model)
                        {
                            <tr>
                                <td>@m.MovementDate.ToString("dd MMM yyyy HH:mm")</td>
                                <td>@m.Product?.ProductName</td>
                                <td>
                                    <span class="badge @(m.MovementType == "IN" ? "bg-success" : "bg-danger")">
                                        @(m.MovementType == "IN" ? "Stock In" : "Stock Out")
                                    </span>
                                </td>
                                <td class="fw-bold @(m.MovementType == "IN" ? "text-success" : "text-danger")">
                                    @(m.MovementType == "IN" ? "+" : "-")@m.Quantity
                                </td>
                                <td>@m.Reference</td>
                                <td>@m.Notes</td>
                                <td>@m.CreatedBy</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>