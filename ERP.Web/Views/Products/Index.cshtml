@using ERP.Core.Models
@model IEnumerable<Product>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Products</h4>
        <p class="text-muted mb-0">Manage inventory products</p>
    </div>
    <a href="/Products/Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add Product
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-primary mb-1"><i class="fas fa-boxes fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count()</h4>
            <p class="text-muted mb-0">Total Products</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-success mb-1"><i class="fas fa-check-circle fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(p => p.CurrentStock > p.ReorderLevel)</h4>
            <p class="text-muted mb-0">In Stock</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-danger mb-1"><i class="fas fa-exclamation-triangle fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Count(p => p.CurrentStock <= p.ReorderLevel)</h4>
            <p class="text-muted mb-0">Low Stock</p>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 text-center">
            <div class="text-warning mb-1"><i class="fas fa-rupee-sign fa-2x"></i></div>
            <h4 class="fw-bold">@Model.Sum(p => p.CurrentStock * p.CostPrice).ToString("N0")</h4>
            <p class="text-muted mb-0">Stock Value (₹)</p>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="p-3 border-bottom">
            <input type="text" id="searchInput" class="form-control"
                   placeholder="Search products..." style="max-width:300px" />
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="prodTable">
                <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Unit</th>
                        <th>Cost Price</th>
                        <th>Sale Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-4 text-muted">
                                <i class="fas fa-boxes fa-2x mb-2 d-block"></i>
                                No products found. Add your first product!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td><span class="badge bg-light text-dark">@p.ProductCode</span></td>
                                <td class="fw-500">@p.ProductName</td>
                                <td>@p.Category</td>
                                <td>@p.Unit</td>
                                <td>₹@p.CostPrice.ToString("N2")</td>
                                <td>₹@p.SalePrice.ToString("N2")</td>
                                <td>
                                    <span class="badge @(p.CurrentStock > p.ReorderLevel ? "bg-success" : "bg-danger")">
                                        @p.CurrentStock @p.Unit
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(p.CurrentStock > 0 ? "bg-success" : "bg-secondary")">
                                        @(p.CurrentStock > 0 ? "In Stock" : "Out of Stock")
                                    </span>
                                </td>
                                <td>
                                    <a href="/Products/StockIn/@p.Id"
                                       class="btn btn-sm btn-outline-success me-1"
                                       title="Stock In">
                                        <i class="fas fa-plus"></i>
                                    </a>
                                    <a href="/Products/Edit/@p.Id"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            const search = this.value.toLowerCase();
            document.querySelectorAll('#prodTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(search) ? '' : 'none';
            });
        });
    </script>
}