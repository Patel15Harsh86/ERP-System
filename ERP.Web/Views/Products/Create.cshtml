@{
    ViewData["Title"] = "Add Product";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Add Product</h4>
        <p class="text-muted mb-0">Fill in the product details</p>
    </div>
    <a href="/Products" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form method="post" action="/Products/Create">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-500">Product Name</label>
                    <input type="text" name="ProductName" class="form-control"
                           placeholder="Enter product name" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-500">Category</label>
                    <input type="text" name="Category" class="form-control"
                           placeholder="e.g. Electronics, Stationery" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-500">Unit</label>
                    <select name="Unit" class="form-select" required>
                        <option value="">-- Select Unit --</option>
                        <option value="PCS">PCS (Pieces)</option>
                        <option value="KG">KG (Kilogram)</option>
                        <option value="LTR">LTR (Litre)</option>
                        <option value="MTR">MTR (Meter)</option>
                        <option value="BOX">BOX</option>
                        <option value="SET">SET</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-500">Reorder Level</label>
                    <input type="number" name="ReorderLevel" class="form-control"
                           placeholder="Minimum stock level" value="10" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-500">Cost Price (₹)</label>
                    <input type="number" name="CostPrice" class="form-control"
                           placeholder="0.00" step="0.01" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-500">Sale Price (₹)</label>
                    <input type="number" name="SalePrice" class="form-control"
                           placeholder="0.00" step="0.01" required />
                </div>
                <div class="col-12">
                    <label class="form-label fw-500">Description</label>
                    <textarea name="Description" class="form-control" rows="3"
                              placeholder="Product description (optional)"></textarea>
                </div>
                <div class="col-12 mt-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save me-2"></i>Save Product
                    </button>
                    <a href="/Products" class="btn btn-outline-secondary ms-2">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>