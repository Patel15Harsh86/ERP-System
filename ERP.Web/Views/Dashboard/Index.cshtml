@{
    ViewData["Title"] = "Dashboard";
}

<!-- KPI Cards Row 1 -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small">Total Employees</p>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalEmployees</h3>
                </div>
                <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                    <i class="fas fa-users text-primary fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small">Total Products</p>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalProducts</h3>
                    <small class="text-danger">@ViewBag.LowStockProducts low stock</small>
                </div>
                <div class="bg-success bg-opacity-10 rounded-circle p-3">
                    <i class="fas fa-boxes text-success fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small">Pending Orders</p>
                    <h3 class="fw-bold mb-0">@ViewBag.PendingOrders</h3>
                    <small class="text-warning">@ViewBag.UnpaidInvoices unpaid invoices</small>
                </div>
                <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                    <i class="fas fa-shopping-cart text-warning fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small">Total Sales</p>
                    <h3 class="fw-bold mb-0">₹@String.Format("{0:N0}", ViewBag.TotalSales)</h3>
                    <small class="text-muted">All invoices</small>
                </div>
                <div class="bg-danger bg-opacity-10 rounded-circle p-3">
                    <i class="fas fa-rupee-sign text-danger fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- KPI Cards Row 2 -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small">Total Vendors</p>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalVendors</h3>
                </div>
                <div class="bg-info bg-opacity-10 rounded-circle p-3">
                    <i class="fas fa-truck text-info fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small">Total Customers</p>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalCustomers</h3>
                </div>
                <div class="bg-success bg-opacity-10 rounded-circle p-3">
                    <i class="fas fa-user-tie text-success fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small">Stock Value</p>
                    <h3 class="fw-bold mb-0">₹@String.Format("{0:N0}", ViewBag.StockValue)</h3>
                </div>
                <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                    <i class="fas fa-warehouse text-primary fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <p class="text-muted mb-1 small">Total Payroll</p>
                    <h3 class="fw-bold mb-0">₹@String.Format("{0:N0}", ViewBag.TotalPayroll)</h3>
                </div>
                <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                    <i class="fas fa-money-check-alt text-warning fa-lg"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-bold mb-3">
                <i class="fas fa-chart-line me-2 text-primary"></i>Monthly Sales
            </h6>
            <canvas id="salesChart" height="100"></canvas>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-bold mb-3">
                <i class="fas fa-chart-pie me-2 text-success"></i>Invoice Status
            </h6>
            <canvas id="invoiceChart" height="200"></canvas>
        </div>
    </div>
</div>

<!-- Second Charts Row -->
<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-bold mb-3">
                <i class="fas fa-chart-bar me-2 text-warning"></i>HR Overview
            </h6>
            <canvas id="hrChart" height="150"></canvas>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-bold mb-3">
                <i class="fas fa-chart-pie me-2 text-info"></i>Inventory Status
            </h6>
            <canvas id="inventoryChart" height="150"></canvas>
        </div>
    </div>
</div>

<!-- Recent Orders -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold">
        <i class="fas fa-shopping-cart me-2 text-primary"></i>Recent Orders
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Order No</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.RecentOrders != null)
                {
                    @foreach (var order in ViewBag.RecentOrders)
                    {
                        <tr>
                            <td>@order.OrderNumber</td>
                            <td>@order.Customer?.CustomerName</td>
                            <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                            <td>₹@String.Format("{0:N2}", order.TotalAmount)</td>
                            <td>
                                <span class="badge @(order.Status == "Pending" ? "bg-warning text-dark" : "bg-success")">
                                    @order.Status
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Monthly Sales Line Chart
        new Chart(document.getElementById('salesChart'), {
            type: 'line',
            data: {
                labels: [@Html.Raw(ViewBag.ChartLabels ?? "'No Data'")],
                datasets: [{
                    label: 'Sales (₹)',
                    data: [@Html.Raw(ViewBag.ChartData ?? "0")],
                    borderColor: '#1565c0',
                    backgroundColor: 'rgba(21,101,192,0.1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#1565c0',
                    pointRadius: 5
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { callback: v => '₹' + v.toLocaleString() }
                    }
                }
            }
        });

        // Invoice Status Pie Chart
        new Chart(document.getElementById('invoiceChart'), {
            type: 'doughnut',
            data: {
                labels: ['Paid', 'Unpaid', 'Partially Paid'],
                datasets: [{
                    data: [
                        @ViewBag.PaidInvoices,
                        @ViewBag.UnpaidInvoices,
                        @ViewBag.PartialInvoices
                    ],
                    backgroundColor: ['#1D9E75', '#dc3545', '#ffc107'],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // HR Overview Bar Chart
        new Chart(document.getElementById('hrChart'), {
            type: 'bar',
            data: {
                labels: ['Employees', 'Vendors', 'Customers'],
                datasets: [{
                    label: 'Count',
                    data: [
                        @ViewBag.TotalEmployees,
                        @ViewBag.TotalVendors,
                        @ViewBag.TotalCustomers
                    ],
                    backgroundColor: ['#1565c0', '#0288d1', '#1D9E75'],
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });

        // Inventory Status Pie Chart
        new Chart(document.getElementById('inventoryChart'), {
            type: 'pie',
            data: {
                labels: ['In Stock', 'Low Stock', 'Out of Stock'],
                datasets: [{
                    data: [
                        @ViewBag.InStockProducts,
                        @ViewBag.LowStockProducts,
                        @ViewBag.OutOfStockProducts
                    ],
                    backgroundColor: ['#1D9E75', '#ffc107', '#dc3545'],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    </script>
}